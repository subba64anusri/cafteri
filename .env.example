# Copy this file to .env and adjust for your server.
# Never commit the real .env file to version control.

# Port the API + Socket.IO server listens on
PORT=5000

# Local MongoDB connection string (server you manage)
MONGO_URI=mongodb://127.0.0.1:27017/canteenDB

# Comma-separated list of origins allowed to call this API.
# Use the exact origin(s) your frontend is served from in production.
# Example: https://canteen.yourcollege.edu,http://10.177.113.16:8080
CORS_ORIGINS=*

# Default accounts auto-created on first boot if missing.
# Change these immediately after first login in production.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=password123
DEFAULT_CHEF_USERNAME=chef1
DEFAULT_CHEF_PASSWORD=password123
